{
	"name": "reset-dryrun-markus-test",
	"version": "0.0.0",
	"description": "An opinionated, MIT-licensed full-stack TypeScript starter template.",
	"license": "MIT",
	"private": true,
	"type": "module",
	"engines": {
		"node": "24.x"
	},
	"scripts": {
		"build": "npm run build:web && npm run build:server",
		"build:server": "tsup --entry.index src/server/index.ts --entry.migrate src/db/migrate.ts --format esm --out-dir dist-server --clean",
		"build:web": "vite build",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"dev": "concurrently -k -n web,api -c blue,green \"vite\" \"tsx watch --env-file-if-exists=.env src/server/index.ts\"",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint . --max-warnings 0",
		"predev": "npm run db:migrate",
		"prepare": "husky",
		"setup": "npm install && bash scripts/bootstrap.sh",
		"test": "vitest run",
		"test:watch": "vitest",
		"typecheck": "tsc -p src/server/tsconfig.json --noEmit && tsc -p src/web/tsconfig.json --noEmit"
	},
	"dependencies": {
		"@hono/node-server": "^2.0.4",
		"@hono/zod-validator": "^0.8.0",
		"@hookform/resolvers": "^5.4.0",
		"@tanstack/react-query": "^5.101.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"drizzle-orm": "^0.45.2",
		"hono": "^4.12.23",
		"lucide-react": "^1.17.0",
		"pg": "^8.21.0",
		"pino": "^9.14.0",
		"radix-ui": "^1.4.3",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"react-hook-form": "^7.77.0",
		"react-router": "^7.16.0",
		"resend": "^6.12.4",
		"stripe": "^22.2.0",
		"tailwind-merge": "^3.6.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.3.0",
		"@testing-library/dom": "^10.4.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^25.9.1",
		"@types/pg": "^8.20.0",
		"@types/react": "^19.2.16",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.2",
		"concurrently": "^10.0.3",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-react": "^7.37.5",
		"eslint-plugin-react-hooks": "^7.1.1",
		"globals": "^17.6.0",
		"happy-dom": "^20.10.1",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"msw": "^2.14.6",
		"prettier": "^3.8.3",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"tailwindcss": "^4.3.0",
		"tsup": "^8.5.1",
		"tsx": "^4.22.4",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vite": "^8.0.16",
		"vitest": "^4.1.8"
	}
}
