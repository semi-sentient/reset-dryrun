# Test environment — loaded by the Vitest harness (vitest.config.ts loads this
# file via dotenv BEFORE any `src/env.ts` import, and the server setup file
# (src/server/test/setup.ts) reloads it inside each test fork as a belt-and-
# suspenders guard). This file is committed on purpose: it contains only dummy
# values, never real secrets.
#
# Unlike `.env` / `.env.example` (which grow one var per phase), this file
# front-loads the FULL final required-var set NOW. Dummy entries ahead of the
# `src/env.ts` schema are harmless and save editing this file every phase. As
# later phases add real zod validation for these vars, the dummies below already
# satisfy the constraints (SESSION_SECRET >= 32 chars, APP_ORIGIN is a URL, etc.).

# Node environment.
NODE_ENV=test

# Postgres connection string. NOTE: `vibe_starter_test`, a SEPARATE database from
# the dev db (`vibe_starter`). The globalSetup creates and migrates it; the suite
# must NEVER touch the dev db. Credentials match docker-compose.yml's superuser
# (which has CREATEDB).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vibe_starter_test

# Session signing secret (validated >= 32 chars from P4). Dummy value, 48 chars.
SESSION_SECRET=test_session_secret_0123456789_abcdefghijklmnop

# Public origin of the app (validated as a URL from a later phase).
APP_ORIGIN=http://localhost:5173

# Stripe keys (validated from P7/P8). Dummy values — no live calls in tests.
STRIPE_SECRET_KEY=sk_test_dummy
STRIPE_WEBHOOK_SECRET=whsec_dummy

# Anthropic API key (added P8). OPTIONAL + UNUSED by shipped code; left blank so
# the optional-var path is exercised. No live calls in tests.
ANTHROPIC_API_KEY=
