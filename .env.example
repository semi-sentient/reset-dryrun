# Copy this file to `.env` and fill in real values: `cp .env.example .env`.
# `.env` is gitignored — never commit real secrets.
#
# Discipline (see AGENTS.md): every new env var is added here AND to the zod
# schema in src/env.ts (server) or src/env.client.ts (client) in the same change.

# Node environment: development | production | test
NODE_ENV=development

# Postgres connection string. LOCAL: the user/password/database below match the
# defaults in docker-compose.yml, so `docker compose up -d` + this value just work.
# PRODUCTION: use the Railway Postgres add-on's (private) URL — see DEPLOY.md.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vibe_starter

# Public origin of the app (no trailing slash). Used to build magic-link /
# redirect URLs and the CSRF Origin check. LOCAL: the Vite dev server port below.
# PRODUCTION: your deployed web origin (Railway domain or custom domain) — see DEPLOY.md.
APP_ORIGIN=http://localhost:5173

# Secret used to SIGN the session (`sid`) cookie. Must be >= 32 characters.
# Generate one with: `openssl rand -base64 36`. Keep it out of version control.
SESSION_SECRET=change-me-to-a-random-string-at-least-32-chars

# Bootstrap + break-glass: comma-separated emails that resolve to at least the
# `admin` role at login (case-insensitive). Roles are durable + upgrade-only, so
# this only ever raises a role, never demotes — removing an email does NOT revoke
# admin. Set it once to mint the first admin, then invite the rest from in-app
# (invites grant durable roles). Everyone else is a regular `user`. Blank is fine.
ADMIN_EMAILS=

# Resend API key for sending magic-link emails. OPTIONAL: when unset, the 6-digit
# login code is printed to the server console instead — so you can develop the
# auth flow without a Resend account. Get a key at https://resend.com.
RESEND_API_KEY=

# Stripe SECRET key (server-only — NEVER expose it / no VITE_ prefix). Creates
# Checkout Sessions and calls the Stripe API. Use a test-mode key (sk_test_...)
# in dev. Get keys at https://dashboard.stripe.com/test/apikeys.
STRIPE_SECRET_KEY=sk_test_...

# Stripe WEBHOOK signing secret (server-only). Verifies POST /api/stripe/webhook
# signatures against the raw request body. In local dev, run
# `stripe listen --forward-to localhost:3000/api/stripe/webhook` — it prints the
# whsec_... value to paste here.
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe PUBLISHABLE key (safe to expose — it ships in the browser bundle).
# OPTIONAL: the shipped flow is hosted Checkout (a redirect) and needs NO
# client-side Stripe config; only set this if you add Stripe.js / Elements.
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Anthropic API key. OPTIONAL and UNUSED by the shipped code — a validated slot
# for builders who add AI features (read it via `env.ANTHROPIC_API_KEY`). Leave
# blank unless you wire up the Claude API. Get a key at https://console.anthropic.com.
ANTHROPIC_API_KEY=
