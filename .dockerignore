# Keep the Docker build context lean. Each image rebuilds deps and bundles from
# source, so host build artifacts and installed deps never need to be copied in —
# shipping them would only bloat the context and risk leaking stale local output.
#
# Be careful: do NOT add `src/` or `src/db/migrations/` here — the api runtime
# image COPYs `src/db/migrations/` (the .sql files + meta/_journal.json) and both
# builds compile from `src/`. Likewise keep `index.html` (Vite's entry lives at the
# repo root), `package*.json`, and the tsup/vite/ts configs out of this list.

# Dependencies (reinstalled in-image via `npm ci`)
node_modules
**/node_modules

# Build output (rebuilt inside each image)
dist
dist-server
coverage
*.tsbuildinfo
bundle-visualizer.html

# Secrets and local env — NEVER bake these into an image layer
.env
.env.*
!.env.example

# Version control
.git
.gitignore
.gitattributes

# Agent / planning / scratch material
.agents
.claude
.roo
skills-lock.json

# Editor / OS cruft
.vscode
.DS_Store
**/.DS_Store

# Logs and temp dirs
logs
*.log
npm-debug.log*
temp
.temp
archived

# CI / tooling not needed at build time
.github
.husky

# The deploy docs and Docker plumbing themselves don't belong in the context
DEPLOY.md
Dockerfile.api
Dockerfile.web
nginx.conf
docker-compose.yml
.dockerignore
railway.json
